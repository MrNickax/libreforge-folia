+        TriggerParameter.VICTIM
+    )
+
+    override fun onTrigger(config: Config, data: TriggerData, compileData: NoCompileData): Boolean {
+        val victim = data.victim ?: return false
+        val glowing = config.getBoolOrNull("glowing") ?: true
